ANTHROPIC_API_KEY=your_anthropic_api_key_here
PORT=3001

# App URL (used for Stripe redirect URLs + origin lock)
# Production: APP_URL=https://grantsearchpro.turtlelogisticsllc.com
APP_URL=http://localhost:5173

# Auth
# JWT_SECRET: at least 32 random chars — generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
# ENCRYPT_KEY: exactly 32 chars for AES-256 — generate with: openssl rand -hex 16
ENCRYPT_KEY=change-me-exactly-32-chars-long!!

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_AGENCY=price_...

# Email digest (weekly hot grant matches)
# Option A: Gmail — enable "App Passwords" in Google Account > Security
SMTP_USER=you@gmail.com
SMTP_PASS=your_gmail_app_password

# Option B: Custom SMTP server
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@yourdomain.com
# SMTP_PASS=yourpassword

# Where to send the weekly digest
DIGEST_EMAIL=kevanaenterprises@gmail.com

# Cron schedule for digest (default: Mondays at 8am)
# DIGEST_CRON=0 8 * * 1
